{
  "name": "@tsonic/express",
  "version": "10.0.49",
  "private": false,
  "description": "Native Tsonic implementation of Express",
  "type": "module",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./src/index.ts"
    },
    "./index.js": {
      "types": "./index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "index.d.ts",
    "src/**/*.ts",
    "tsonic.package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/tests/runtime/*.test.js dist/tests/tsonic/*.test.js",
    "selftest": "bash scripts/selftest.sh",
    "check:branches": "bash scripts/check-branch-hygiene.sh",
    "publish:10": "bash scripts/selftest.sh && npm publish --access public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tsoniclang/express.git"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
